# =================================================================
# Plantilla de variables de entorno (.env.example)
# Copia este archivo como '.env' y completa los valores reales.
# No subas el archivo .env a Git (está en .gitignore).
# =================================================================

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- Telegram Bot (crear bot con @BotFather en Telegram) ---
# Token que entrega BotFather (NO lo compartas públicamente)
TELEGRAM_BOT_TOKEN=

# Chat ID del estudiante de prueba (p. ej. obtenido con @userinfobot)
TELEGRAM_STUDENT_CHAT_ID=

# Opcional: chat ID del docente para recibir un resumen de cada respuesta
TELEGRAM_TEACHER_CHAT_ID=

# Opcional: si configuras webhook con secret_token, Telegram envía este header
TELEGRAM_WEBHOOK_SECRET=

# --- IA (Groq) — generación de preguntas de opción múltiple ---
GROQ_API_KEY=

# --- Base de datos (reservado para futuras versiones) ---
# DATABASE_URL=
