# Variables para el servicio comprendo-api en Render (Environment → Add)
# Copia y pega en el dashboard; reemplaza los valores entre < >.

ASPNETCORE_ENVIRONMENT=Production

# Supabase — URI completa con contraseña (obligatoria)
ConnectionStrings__DefaultConnection=postgresql://postgres:<TU_PASSWORD>@db.vophfrxqguobngyplrdc.supabase.co:5432/postgres

# Opcional: mismo valor que la línea anterior
