PORT=3000

# Clave de API de Zhipu AI (GLM)
ZHIPU_API_KEY=tu_api_key_aqui
ZHIPU_MODEL=glm-4-flash
ZHIPU_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# IA para preguntas: Groq (gsk_...) o xAI/Grok (xai-...) — el código detecta el prefijo
GROQ_API_KEY=tu_clave_groq_gsk_o_xai_aqui
# GROQ_MODEL=llama-3.3-70b-versatile
# XAI_MODEL=grok-3
# (opcional, varios separados por coma: grok-3,grok-4.3)

# Opcional: Google Gemini (se prueba antes que Groq/xAI)
# GEMINI_API_KEY=


# Configuración de Telegram Bot
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token_aqui
TELEGRAM_STUDENT_CHAT_ID=tu_telegram_chat_id_estudiantes

# Configuración de Conexión al Core API .NET
CORE_API_URL=http://localhost:5253
INTEGRATION_API_KEY=dev-integration-api-key

# Orígenes permitidos del panel docente (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
